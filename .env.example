# 서버 포트 (기본 3000)
PORT=3000

# 전산(온더라인) 노티 수신 API URL - 설정 시 가공된 노티 전송 활성화
# INTERNAL_NOTI_URL=https://your-internal-api.example.com/noti

# J-Pay APM 노티 → Soonpay 전산(JHU) 무가공 미러 URL (미설정 시 기본값 사용)
# JPAY_SOONPAY_MIRROR_URL=https://api.soonpay.co.kr/noti/CHILL/JHU
# 선택: J-Pay 비동기 노티 sign 필드 MD5 검증 (값이 1 또는 true 일 때)
# JPAY_VERIFY_NOTIFY_SIGN=
# JPAY_NOTIFY_API_KEY=
# JPAY_API_KEY=
